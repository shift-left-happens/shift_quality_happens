# Railway (production)
DB_URL=jdbc:mysql://your-host:port/railway?useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your_railway_password_here

# Docker (local)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=shift_happens
LOCAL_DB_USERNAME=root
# Security (optional for local dev — defaults are set in application.properties)
# In production, override these with strong random values.
JWT_SECRET=some-long-random-secret-at-least-32-characters
PASSWORD_PEPPER=some-other-secret-value
