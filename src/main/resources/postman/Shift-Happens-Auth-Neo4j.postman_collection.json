                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/neo4j/employees",
              "host": ["{{baseUrl}}"],
              "path": ["neo4j", "employees"]
            }
          },
          "response": []
        },
        {
