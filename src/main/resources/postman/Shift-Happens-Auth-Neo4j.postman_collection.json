{
  "info": {
    "name": "Shift Happens - Auth + Neo4j",
    "_postman_id": "4b130bab-b438-4d72-b61a-62e1c83513a4",
    "description": "Login and Neo4j migration requests for Shift Happens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "email", "value": "admin@shift.dk" },
    { "key": "password", "value": "password123" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Migrator",
      "item": [
        {
          "name": "POST Migrate to Neo4j",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/migrate/neo4j",
              "host": ["{{baseUrl}}"],
              "path": ["migrate", "neo4j"]
            }
          },
          "response": []
        },
        {
          "name": "POST Migrate All",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/migrate",
              "host": ["{{baseUrl}}"],
              "path": ["migrate"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Neo4j Reads",
      "item": [
        {
          "name": "GET Employees from Neo4j",
          "request": {
            "auth": {
              "type": "bearer",
