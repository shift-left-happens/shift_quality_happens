{
  "info": {
    "name": "Shift Happens Migrate",
    "_postman_id": "shift-happens-multi-db",
    "description": "Shift Happens API — MySQL CRUD + MongoDB/Neo4j migration endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "MySQL — Employees",
      "item": [
        {
          "name": "GET all employees",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/employees", "host": ["{{baseUrl}}"], "path": ["employees"] }
          }
        },
        {
          "name": "GET employee by id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/employees/1", "host": ["{{baseUrl}}"], "path": ["employees", "1"] }
          }
        },
        {
          "name": "POST create employee",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/employees", "host": ["{{baseUrl}}"], "path": ["employees"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeNumber\": \"EMP-999\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"test@company.com\",\n  \"loginPassword\": \"secret\",\n  \"fkUserRoleId\": 1,\n  \"phoneNumber\": \"+45 00000000\",\n  \"hireDate\": \"2025-01-01\",\n  \"employmentStatus\": \"ACTIVE\",\n  \"primaryWorkLocationId\": 1\n}"
            }
          }
        },
        {
          "name": "PATCH update employee",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/employees/1", "host": ["{{baseUrl}}"], "path": ["employees", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employmentStatus\": \"INACTIVE\"\n}"
            }
          }
        },
        {
          "name": "DELETE employee",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/employees/1", "host": ["{{baseUrl}}"], "path": ["employees", "1"] }
          }
        }
      ]
    },
    {
      "name": "MySQL — Departments",
      "item": [
        {
          "name": "GET all departments",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/departments", "host": ["{{baseUrl}}"], "path": ["departments"] }
          }
        },
        {
          "name": "GET department by id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/departments/1", "host": ["{{baseUrl}}"], "path": ["departments", "1"] }
          }
        },
        {
          "name": "POST create department",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/departments", "host": ["{{baseUrl}}"], "path": ["departments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"departmentName\": \"New Department\",\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "PATCH update department",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/departments/1", "host": ["{{baseUrl}}"], "path": ["departments", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": false\n}"
            }
          }
        },
        {
          "name": "DELETE department",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/departments/1", "host": ["{{baseUrl}}"], "path": ["departments", "1"] }
          }
        }
      ]
    },
    {
      "name": "Migrator",
      "item": [
        {
          "name": "POST migrate all (MySQL → MongoDB + Neo4j)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/migrate", "host": ["{{baseUrl}}"], "path": ["migrate"] }
          }
        },
        {
          "name": "POST migrate to MongoDB only",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/migrate/mongo", "host": ["{{baseUrl}}"], "path": ["migrate", "mongo"] }
          }
        },
        {
          "name": "POST migrate to Neo4j only",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/migrate/neo4j", "host": ["{{baseUrl}}"], "path": ["migrate", "neo4j"] }
          }
        }
      ]
    },
    {
      "name": "MongoDB — Employees",
      "item": [
        {
          "name": "GET all employees (MongoDB)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/mongo/employees", "host": ["{{baseUrl}}"], "path": ["mongo", "employees"] }
          }
        },
        {
          "name": "GET employee by id (MongoDB)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/mongo/employees/:id", "host": ["{{baseUrl}}"], "path": ["mongo", "employees", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },
